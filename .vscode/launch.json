{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go API Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/server",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "BILIGO_CONFIG": "${workspaceFolder}/config.yaml"
      },
      "args": []
    },
    {
      "name": "Vite Dev Server",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "cwd": "${workspaceFolder}/web",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome",
        "webRoot": "${workspaceFolder}/web/src"
      }
    },
    {
      "name": "Web Frontend",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/web/src"
    }
  ],
  "compounds": [
    {
      "name": "Biligo Full Stack",
      "configurations": ["Go API Server", "Vite Dev Server"],
      "stopAll": true
    }
  ]
}
